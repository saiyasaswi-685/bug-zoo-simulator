{
  "name": "bug-zoo-simulator",
  "version": "1.0.0",
  "description": "Bug Zoo Simulator API with Prometheus Metrics and Structured Logging",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main/index.js",
    "dev": "ts-node src/main/index.ts",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:coverage": "jest --runInBand --detectOpenHandles --forceExit --coverage",
    "capture-evidence": "bash scripts/capture-evidence.sh"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pino": "^9.1.0",
    "prom-client": "^15.1.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
