# HTTP port the API server listens on
PORT=3000

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Base interval (ms) between simulated zoo events, honored by the engine
# (src/engine/simulator/index.ts). A +/-20% jitter is applied around this
# value so ticks aren't perfectly robotic. Falls back to 2000ms if unset
# or invalid.
SIMULATION_INTERVAL_MS=2000

# Path to the SQLite database file. For local development this is a
# relative path in the project root. In Docker this is overridden to
# /app/data/bug_zoo.db, which is backed by a named volume (see
# docker-compose.yml) so data survives container restarts.
DATABASE_PATH=bug_zoo.db

# Standard Node environment flag
NODE_ENV=development
